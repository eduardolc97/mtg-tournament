generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tournament {
  id                             String   @id @map("id")
  name                           String
  createdAt                      DateTime @map("created_at")
  players                        Json     @db.JsonB
  rounds                         Json     @db.JsonB
  leagueYear                     Int      @map("league_year")
  leagueMonth                    Int      @map("league_month")
  modality                       String   @default("weekly_cmd100")
  doublesIncludeFourthSwissRound Boolean? @map("doubles_include_fourth_swiss_round")

  @@map("tournaments")
}

model PresetPlayerName {
  id   Int    @id @default(autoincrement()) @map("id")
  name String @unique @map("name")

  @@map("preset_player_names")
}
