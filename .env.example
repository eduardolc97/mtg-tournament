# Prisma (local): Supabase → Settings → Database → URI (direct, port 5432)
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres"

VITE_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
VITE_SUPABASE_PUBLISHABLE_DEFAULT_KEY="your_publishable_or_anon_key"
# Optional alternative name supported by the app:
# VITE_SUPABASE_ANON_KEY="eyJ..."

# Optional: when set (non-empty), the app shows /login and requires this token (sessionStorage per tab).
# Generate a long random string; do not commit the real value.
# VITE_APP_ACCESS_TOKEN=""
